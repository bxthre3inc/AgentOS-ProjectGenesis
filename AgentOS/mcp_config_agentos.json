{
  "name": "zo-antigravity-agentos-mesh",
  "description": "3-Way MCP peer mesh: Zo.Computer + Antigravity IDE + AgentOS workforce. Connect AgentOS to join the shared workspace.",
  "transport": "stdio",
  "command": "python3",
  "args": [
    "/path/to/agentos/main.py",
    "mcp"
  ],
  "note": "Update 'command' and 'args' to point to your AgentOS installation. The mcp_server_url below is what AgentOS should register via the register_peer tool.",
  "peer_registration": {
    "agent_id": "agentos",
    "mcp_server_url": "http://YOUR_AGENTOS_HOST:8080/mcp",
    "api_key_env": "AGENTOS_MCP_API_KEY",
    "capabilities": ["invoke_agents", "assign_task", "query_memory", "war_room", "get_ledger", "receive_code"]
  },
  "sync_server": {
    "url": "http://localhost:7878",
    "dashboard": "http://localhost:7880"
  },
  "tools_available_to_agentos": [
    "ping", "sync_resource", "read_resource", "list_workspace",
    "set_secret", "get_secret", "list_secrets",
    "toggle_feature", "list_features",
    "issue_command", "poll_commands",
    "send_message", "get_messages",
    "list_extensions", "toggle_extension",
    "get_actions_log",
    "register_peer", "get_peers", "get_session"
  ],
  "antigravity_ide_tools_available": [
    "open_file", "edit_file", "create_file", "delete_file", "read_file",
    "get_file_tree", "search_files", "run_terminal", "get_diagnostics",
    "set_breakpoint", "get_session", "update_cursor", "invoke_antigravity"
  ]
}

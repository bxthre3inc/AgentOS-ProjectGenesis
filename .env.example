# AgentOS Environment Variables Example
# Copy to .env and configure accordingly

# --- System Profile ---
AGENTOS_PROFILE=desktop        # desktop | mobile
AGENTOS_IS_SERVER=false        # set to 'true' for Zo Server (24GB RAM)
AGENTOS_IS_MOBILE=false        # set to 'true' for Android (S67)

# --- Local AI Infrastructure (Ollama / Whisper / Piper) ---
AGENTOS_LLM_URL=http://localhost:11434/v1
AGENTOS_LLM_MODEL=phi3:3.8b-mini-instruct-4k-q4_K_M
AGENTOS_STT_URL=http://localhost:5000/stt
AGENTOS_TTS_URL=http://localhost:5001/tts

# --- Mesh Security ---
# Use 'openssl rand -hex 32' to generate these
AGENTOS_MESH_KEY=yoursecretmeshkey
AGENTOS_ENCRYPTION_KEY=yoursecretledgerkey

# --- Corporate Communication (SignalWire) ---
SIGNALWIRE_PROJECT_ID=your-project-id
SIGNALWIRE_TOKEN=your-token
SIGNALWIRE_SPACE=your-space.signalwire.com
SIGNALWIRE_NUMBER=+1234567890

# --- Database & Storage ---
DATABASE_URL=postgresql://localhost:5432/agentos
VECTOR_DB_URL=localhost:6333

  "name": "zag-mesh-single-slot",
  "description": "Unified 3-Way MCP Mesh (Hub + Dashboard + IDE Server)",
  "version": "1.0.0",
  "runtime": "python3",
  "entrypoint": "python3 main.py mesh",
  "dependencies": "requirements.txt",
  "env": {
    "AGENTIC_BUSINESS_EMPIRE_MCP_API_KEY": {
      "required": true,
      "description": "API Key for AgenticBusinessEmpire peer communication"
    },
    "PORT": {
      "required": false,
      "default": "7880",
      "description": "Port for the Mesh Dashboard"
    }
  },
  "hosting": {
    "type": "managed-service",
    "managed": true,
    "dashboard_url": "https://{SLOT_ID}.zo.hosted"
  }
}
